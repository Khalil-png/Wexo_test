rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Profiles
    match /profiles/{userId} {
      allow read: if isSignedIn();
      allow write: if isOwner(userId);
    }

    // Notifications
    match /notifications/{notificationId} {
      function isValidNotification(data) {
        return data.user_id is string && 
               data.type in ['message', 'friend_request', 'call', 'like'] &&
               data.sender_id is string &&
               data.status in ['unread', 'read', 'pending'];
      }

      allow read: if isSignedIn() && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn() && isValidNotification(incoming());
      allow update: if isSignedIn() && resource.data.user_id == request.auth.uid && 
                   incoming().diff(existing()).affectedKeys().hasOnly(['status']);
      allow delete: if isSignedIn() && resource.data.user_id == request.auth.uid;
    }

    // Add other collections from blueprint as needed
    match /messages/{messageId} {
      allow read, write: if isSignedIn(); // Simplified for now, will harden later
    }

    match /posts/{postId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
    
    match /videos/{videoId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /likes/{likeId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /comments/{commentId} {
      allow read: if true;
      allow write: if isSignedIn();
    }
  }
}
