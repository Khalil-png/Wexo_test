rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Notifications
    match /notifications/{notificationId} {
      function isValidNotification(data) {
        return data.user_id is string && 
               data.user_id.size() <= 128 &&
               data.type in ['message', 'friend_request', 'call', 'like'] &&
               data.sender_id is string &&
               data.sender_id.size() <= 128 &&
               data.status in ['unread', 'read', 'pending'];
      }

      // On autorise la lecture si c'est pour l'utilisateur
      // Note: On utilise l'ID PocketBase passé dans les champs pour filtrer
      // Comme on utilise signInAnonymously, on ne peut pas facilement vérifier l'UID Firebase contre le user_id PocketBase sans session partagée
      // Pour ce prototype, on autorise la lecture si le user_id correspond (le client filtre déjà)
      allow read: if isSignedIn() && resource.data.user_id != null;
      
      // Autoriser la création par n'importe quel utilisateur connecté (anonyme ou non)
      allow create: if isSignedIn() && isValidNotification(incoming());
      
      // Mise à jour (ex: marquer comme lu)
      allow update: if isSignedIn() && 
                   incoming().diff(existing()).affectedKeys().hasOnly(['status']);
                   
      allow delete: if isSignedIn();
    }

    // Profiles
    match /profiles/{userId} {
      allow read: if true;
      allow write: if isSignedIn(); 
    }
  }
}
