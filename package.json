{
  "name": "wexo-social",
  "private": true,
  "version": "0.0.1",
  "description": "Wexo Social Network Application",
  "author": "Wexo Team",
  "type": "module",
  "main": "main.cjs",
  "scripts": {
    "dev": "vite",
